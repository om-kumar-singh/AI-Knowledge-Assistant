# Browser origins allowed to call the API (comma-separated). Add http://YOUR_LAN_IP:3000 if you use Next "Network" URL.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

OPENAI_API_KEY=

# SQLAlchemy / psycopg2 — use postgresql+psycopg2:// or postgresql:// (psycopg2 is default driver)
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/ai_knowledge_assistant

# Set true only for local dev to auto-create tables from ORM metadata (prefer schema.sql / migrations in prod)
AUTO_CREATE_TABLES=false

# Log SQL (verbose; use only when debugging)
DATABASE_ECHO=false

# Directory for uploaded files (relative to backend root)
UPLOADS_DIR=uploads

# ChromaDB on-disk directory (under backend root)
CHROMA_PERSIST_DIR=chroma_data

# sentence-transformers model id (local, no API key)
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Default top-k chunks for POST /api/query
RAG_DEFAULT_TOP_K=5

# Local HuggingFace text2text model (FLAN-T5)
LLM_MODEL_NAME=google/flan-t5-base
LLM_MAX_NEW_TOKENS=200
LLM_MAX_CONTEXT_CHARS=2000
LLM_MAX_HISTORY_CHARS=1500

# Messages loaded from DB per /api/query (short memory)
CHAT_HISTORY_LIMIT=10
